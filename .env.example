# Application
VITE_APP_NAME=My App
VITE_APP_DESCRIPTION=Built with viiibin

# Auth0 (leave blank to disable auth)
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=

# API — backend URL for /api proxy (default: same origin)
VITE_API_BASE_URL=/api

# AI Chat Widget — set to "none" to disable, or "anthropic"/"openai"
VITE_AI_PROVIDER=none
VITE_AI_MODEL=claude-sonnet-4-20250514

# Analytics
VITE_ENABLE_ANALYTICS=false

# Theme
VITE_PRIMARY_COLOR=#6366f1

# Push Notifications (Android only)
VITE_FCM_SENDER_ID=
